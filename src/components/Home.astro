---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.svelte';
import Section from '@components/Section.svelte';
import Article from '@components/Article.svelte';
import Badge from '@components/Badge.svelte';
import TechIcon from '@components/TechIcon.svelte';
import TechCard from '@components/TechCard.svelte';
import ProjectCard from '@components/ProjectCard.svelte';
import TimelineRow from '@components/TimelineRow.svelte';
import LongPathRow from '@components/LongPathRow.svelte';
import avatar from '../assets/avatar.png';

import {
  getDictionary,
  formatMonthYear,
  formatYearsMonths,
  monthsBetween,
  totalExperienceMonths,
  plural,
  LOCALES,
  type Locale
} from '@i18n';
import { getContent, buildTimeline } from '@content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);
const content = getContent(locale);
const timeline = buildTimeline(content);

const otherLocale: Locale = LOCALES.find((l) => l !== locale) ?? 'en';
const otherLocaleHref = `/${otherLocale}/`;

const techStack = [
  ...content.skills.hard.languages,
  ...content.skills.hard.technologies
];

const currentExperience = content.experience.filter((e) => !e.end);
const currentJobs = currentExperience.map(
  (e) => e.shortLabel ?? e.company.split(' ').pop() ?? e.company
);
const currentRoles = currentExperience
  .map((e) => e.position)
  .filter((p): p is string => Boolean(p));

const stackShort = content.skills.main.slice(0, 3).map((s) => s.title);

const telegramLink = content.nav.find((n) => n.slug === 'telegram');
const xLink = content.nav.find((n) => n.slug === 'x');
const linkedinLink = content.nav.find((n) => n.slug === 'linkedin');

const contactLinks = [
  ...(telegramLink
    ? [{ href: telegramLink.href, label: 'telegram' }]
    : []),
  { href: `mailto:${content.email}`, label: 'email' },
  ...(xLink ? [{ href: xLink.href, label: 'x.com' }] : []),
  ...(linkedinLink
    ? [{ href: linkedinLink.href, label: 'linkedin' }]
    : [])
];

function handleFromUrl(href: string): string {
  try {
    const url = new URL(href);
    const path = url.pathname.replace(/^\/+|\/+$/g, '');
    return path || url.hostname;
  } catch {
    return href;
  }
}

const connectLinks = [
  {
    href: `mailto:${content.email}`,
    label: 'email',
    handle: content.email,
    slug: 'email'
  },
  ...(xLink
    ? [
        {
          href: xLink.href,
          label: 'x.com',
          handle: `@${handleFromUrl(xLink.href)}`,
          slug: 'x'
        }
      ]
    : []),
  ...(linkedinLink
    ? [
        {
          href: linkedinLink.href,
          label: 'linkedin',
          handle: handleFromUrl(linkedinLink.href),
          slug: 'linkedin'
        }
      ]
    : []),
  ...(telegramLink
    ? [
        {
          href: telegramLink.href,
          label: 'telegram',
          handle: `@${handleFromUrl(telegramLink.href)}`,
          slug: 'telegram'
        }
      ]
    : [])
];

const yearKeyword = dict.parse.yearKeyword;
const yearPrefix = yearKeyword ? `\\s*${yearKeyword}` : '';
const longPathYearRe = new RegExp(`^(\\d{4})${yearPrefix}:\\s*(.+)$`, 'i');

type LongPathEntry = {
  year: number;
  title: string;
  description: string;
  bullets: string[];
};

const longPath: LongPathEntry[] = [];
for (const block of content.about) {
  let current: LongPathEntry | null = null;
  for (const line of block.split('\n')) {
    const m = line.match(longPathYearRe);
    if (m) {
      if (current) longPath.push(current);
      const year = Number(m[1]);
      const body = m[2].trim();
      const splitIdx = body.search(/[.!?](?:\s|$)/);
      const title = splitIdx > 0 ? body.slice(0, splitIdx) : body;
      const description = splitIdx > 0 ? body.slice(splitIdx + 2).trim() : '';
      current = {
        year,
        title: title.trim(),
        description,
        bullets: []
      };
    } else if (current) {
      const trimmed = line.trim();
      if (!trimmed) continue;
      if (trimmed.startsWith('- ')) {
        current.bullets.push(trimmed.slice(2));
      } else {
        current.description = current.description
          ? `${current.description} ${trimmed}`
          : trimmed;
      }
    }
  }
  if (current) longPath.push(current);
}
longPath.sort((a, b) => a.year - b.year);

const aboutShort = content.about[0]?.split('\n').slice(0, 2) ?? [];

const bulletedHeadersRe = dict.parse.bulletedHeaders;

type DescriptionBlock = {
  label?: string;
  isBulleted: boolean;
  items: string[];
};

function parseDescription(desc?: string): DescriptionBlock[] {
  if (!desc) return [];
  const lines = desc.split('\n').filter((row) => row.trim().length > 0);
  const blocks: DescriptionBlock[] = [];
  let current: DescriptionBlock = { isBulleted: false, items: [] };
  for (const raw of lines) {
    const line = raw.trim();
    if (/:$/.test(line) && !line.startsWith('-')) {
      if (current.items.length || current.label) blocks.push(current);
      const label = line.slice(0, -1);
      current = {
        label,
        isBulleted: bulletedHeadersRe.test(label),
        items: []
      };
    } else if (line.startsWith('- ')) {
      current.items.push(line.slice(2));
    } else {
      current.items.push(line);
    }
  }
  if (current.items.length || current.label) blocks.push(current);
  return blocks;
}

const totalExperienceLabel = formatYearsMonths(
  totalExperienceMonths(content.experience),
  locale,
  dict
);

const projectsMeta = `${content.projects.length} ${plural(content.projects.length, locale, dict.count.project)}`;

function sectionTitle(key: typeof content.sections[number]['key']): string {
  return dict.sections[key];
}
---

<Layout title={content.fullName} {locale}>
  <main class="mx-auto w-full max-w-[1280px] 2xl:max-w-[1440px]">
    <Header
      client:load
      email={content.email}
      {currentJobs}
      {currentRoles}
      desiredPositions={content.desiredPositions}
      {stackShort}
      {contactLinks}
      {connectLinks}
      sections={content.sections.map((s) => ({
        number: s.number,
        title: sectionTitle(s.key),
        id: s.id
      }))}
      avatarSrc={avatar.src}
      avatarAlt={content.fullName}
      connectLabel={dict.header.connect}
      contactWaysHeader={dict.header.contactWaysHeader}
      jobSearchLabel={dict.header.jobSearch}
      panelLabels={dict.header.panel}
      {locale}
      {otherLocale}
      {otherLocaleHref}
      heroTitleStart={content.hero.titleStart}
      heroTitleAccent={content.hero.titleAccent}
      heroTitleEnd={content.hero.titleEnd}
      heroIntroHtml={content.hero.introHtml}
    />

    {
      aboutShort.length > 0 && (
        <Section
          client:load
          number="01"
          title={sectionTitle('about')}
          id="about"
        >
          <article class="space-y-6 text-base leading-relaxed sm:text-lg 2xl:text-xl">
            {aboutShort.map((row) => (
              <p class="text-ink-soft dark:text-ink-dark-soft">{row}</p>
            ))}
          </article>
        </Section>
      )
    }

    {
      longPath.length > 0 && (
        <Section
          client:load
          number="02"
          title={sectionTitle('longPath')}
          id="longpath"
        >
          <section>
            {longPath.map((row, i) => (
              <LongPathRow
                client:load
                year={row.year}
                title={row.title}
                description={row.description}
                bullets={row.bullets}
                isLast={i === longPath.length - 1}
              />
            ))}
          </section>
        </Section>
      )
    }

    {
      content.experience?.length > 0 && (
        <Section
          client:load
          number="03"
          title={sectionTitle('experience')}
          meta={totalExperienceLabel}
          id="experience"
        >
          {content.experience.map(
            (
              {
                company,
                position: pos,
                begin,
                end,
                description,
                skills: expSkills
              },
              i
            ) => {
              if (!company) return null;
              const blocks = parseDescription(description);
              const durationLabel = formatYearsMonths(
                monthsBetween(begin, end),
                locale,
                dict
              );
              const beginLabel = formatMonthYear(begin, locale);
              const endLabel = end
                ? formatMonthYear(end, locale)
                : dict.duration.presentTime;
              return (
                <Article
                  client:load
                  title={company}
                  subtitle={pos}
                  dateLabel={`${beginLabel} — ${endLabel}`}
                  durationLabel={durationLabel}
                  index={i + 1}
                >
                  {blocks.length > 0 && (
                    <section class="text-ink-soft dark:text-ink-dark-soft space-y-4 text-sm leading-relaxed sm:text-base 2xl:text-lg">
                      {blocks.map((block) => (
                        <section class="space-y-2">
                          {block.label && (
                            <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                              {block.label}
                            </p>
                          )}
                          {block.isBulleted ? (
                            <ul class="space-y-1.5">
                              {block.items.map((item) => (
                                <li class="flex gap-2.5">
                                  <span
                                    class="flex h-[1.625em] shrink-0 items-center"
                                    aria-hidden="true"
                                  >
                                    <span class="bg-rust/70 dark:bg-rust-soft/70 block h-1 w-1 rounded-full" />
                                  </span>
                                  <span>{item}</span>
                                </li>
                              ))}
                            </ul>
                          ) : (
                            block.items.map((row) => <p>{row}</p>)
                          )}
                        </section>
                      ))}
                    </section>
                  )}
                  {expSkills && expSkills.length > 0 && (
                    <ul class="flex flex-wrap gap-2 pt-3">
                      {expSkills.map(({ title, slug }) => (
                        <li
                          class="border-ink/15 hover:border-rust/40 dark:border-ink-dark/20 dark:hover:border-rust-soft/45 inline-flex items-center gap-1.5 rounded-sm border px-2.5 py-1 transition"
                          title={title}
                        >
                          <i class="text-muted dark:text-ink-dark-soft flex h-3.5 w-3.5 items-center justify-center">
                            <TechIcon
                              client:load
                              slug={slug}
                              title={title}
                              size={14}
                            />
                          </i>
                          <span class="font-jetbrains-mono text-2xs tracking-label text-ink-soft dark:text-ink-dark-soft uppercase 2xl:text-sm">
                            {title}
                          </span>
                        </li>
                      ))}
                    </ul>
                  )}
                </Article>
              );
            }
          )}
        </Section>
      )
    }

    {
      content.projects?.length > 0 && (
        <Section
          client:load
          number="04"
          title={sectionTitle('projects')}
          meta={projectsMeta}
          id="projects"
        >
          <section class="grid gap-4 sm:gap-5 md:grid-cols-2 lg:grid-cols-3 2xl:gap-6">
            {content.projects.map((p, i) => (
              <ProjectCard
                client:load
                name={p.name}
                description={p.description}
                stack={p.stack}
                github={p.github}
                gitlab={p.gitlab}
                index={i + 1}
              />
            ))}
          </section>
        </Section>
      )
    }

    {
      timeline?.length > 0 && (
        <Section
          client:load
          number="05"
          title={sectionTitle('timeline')}
          id="timeline"
        >
          <section>
            {timeline.map(({ year, title, subtitle }) => (
              <TimelineRow
                client:load
                year={year}
                title={title}
                subtitle={subtitle}
              />
            ))}
          </section>
        </Section>
      )
    }

    {
      (content.skills.main?.length ||
        content.skills.hard?.languages?.length ||
        content.skills.hard?.technologies?.length ||
        content.skills.hard?.patterns?.length) && (
        <Section
          client:load
          number="06"
          title={sectionTitle('stack')}
          id="stack"
        >
          {content.skills.main?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                {dict.stack.main}
              </p>
              <ul class="flex flex-wrap gap-6 2xl:gap-8">
                {content.skills.main.map(({ title, slug }) => (
                  <li
                    class="text-ink dark:text-ink-dark flex items-center gap-3"
                    title={title}
                  >
                    <i class="flex h-6 w-6 items-center justify-center">
                      <TechIcon
                        client:load
                        slug={slug}
                        title={title}
                        size={24}
                      />
                    </i>
                    <span class="text-sm sm:text-base">{title}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {techStack.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                {dict.stack.langsTech}
              </p>
              <section class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
                {techStack.map(({ title, slug, description }) => (
                  <TechCard
                    client:load
                    title={title}
                    slug={slug}
                    description={description}
                  />
                ))}
              </section>
            </section>
          )}

          {content.skills.hard?.patterns?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                {dict.stack.patterns}
              </p>
              <ul class="flex flex-wrap gap-2">
                {content.skills.hard.patterns.map((name) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}

          {content.skills.tools?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                {dict.stack.tools}
              </p>
              <ul class="flex flex-wrap gap-2">
                {content.skills.tools.map(({ name }) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}

          {content.skills.soft?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                {dict.stack.softSkills}
              </p>
              <ul class="flex flex-wrap gap-2">
                {content.skills.soft.map((name) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}

          {content.skills.other?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                {dict.stack.other}
              </p>
              <ul class="flex flex-wrap gap-2">
                {content.skills.other.map(({ name }) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}
        </Section>
      )
    }

    {
      (content.languages?.length || content.books?.length) && (
        <Section
          client:load
          number="07"
          title={sectionTitle('reading')}
          id="reading"
        >
          <section class="grid gap-10 md:grid-cols-2 2xl:gap-16">
            {content.languages?.length > 0 && (
              <section class="space-y-4">
                <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                  {dict.reading.languages}
                </p>
                <ul class="space-y-3">
                  {content.languages.map(({ title, level }) => (
                    <li class="border-ink/10 dark:border-ink-dark/15 flex items-baseline justify-between gap-4 border-b pb-3">
                      <span class="text-ink dark:text-ink-dark text-base">
                        {title}
                      </span>
                      <span class="font-jetbrains-mono text-2xs tracking-label text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                        {level}
                      </span>
                    </li>
                  ))}
                </ul>
              </section>
            )}
            {content.books?.length > 0 && (
              <section class="space-y-4">
                <p class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm">
                  {dict.reading.books}
                </p>
                <ul class="space-y-3">
                  {content.books.map(({ name, author }) => (
                    <li class="border-ink/10 dark:border-ink-dark/15 space-y-1 border-b pb-3">
                      <p class="text-ink dark:text-ink-dark text-base">
                        {name}
                      </p>
                      <address class="font-jetbrains-mono text-2xs tracking-label text-muted dark:text-ink-dark-soft uppercase not-italic 2xl:text-sm">
                        {author}
                      </address>
                    </li>
                  ))}
                </ul>
              </section>
            )}
          </section>
        </Section>
      )
    }

    <footer
      id="contact"
      class="border-ink/12 dark:border-ink-dark/15 scroll-mt-24 border-t px-4 pt-12 pb-16 sm:px-8 2xl:px-12 2xl:pt-16 2xl:pb-24"
    >
      <section
        class="flex flex-wrap items-center justify-between gap-6 2xl:gap-10"
      >
        <section class="space-y-2">
          <p
            class="font-jetbrains-mono text-2xs tracking-meta text-muted dark:text-ink-dark-soft uppercase 2xl:text-sm"
          >
            {dict.footer.contactLabel}
          </p>
          <a
            href={`mailto:${content.email}`}
            class="font-lora text-rust decoration-rust/30 hover:decoration-rust dark:text-rust-soft text-2xl italic underline underline-offset-4 transition sm:text-3xl 2xl:text-4xl"
          >
            {content.email}
          </a>
        </section>
        <nav class="flex flex-wrap items-center gap-5 2xl:gap-7">
          {
            content.nav.map(({ href, slug, title }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={title}
                class="text-ink-soft hover:text-rust dark:text-ink-dark-soft dark:hover:text-rust-soft flex items-center gap-2 transition"
              >
                <i class="flex h-5 w-5 items-center justify-center">
                  <TechIcon client:load slug={slug} title={title} size={18} />
                </i>
                <span class="font-jetbrains-mono text-2xs tracking-label uppercase 2xl:text-sm">
                  {title}
                </span>
              </a>
            ))
          }
        </nav>
      </section>
    </footer>
  </main>
</Layout>
