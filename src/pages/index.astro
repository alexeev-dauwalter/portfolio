---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.svelte';
import Section from '@components/Section.svelte';
import Article from '@components/Article.svelte';
import Badge from '@components/Badge.svelte';
import TechIcon from '@components/TechIcon.svelte';
import TechCard from '@components/TechCard.svelte';
import ProjectCard from '@components/ProjectCard.svelte';
import TimelineRow from '@components/TimelineRow.svelte';
import LongPathRow from '@components/LongPathRow.svelte';

import {
  about,
  books,
  currentRole,
  email,
  experience,
  fullName,
  languages,
  links,
  location,
  nav,
  position,
  projects,
  sections,
  shortName,
  skills,
  timeline
} from '../data';

const techStack = [...skills.hard.languages, ...skills.hard.technologies];

const currentJobs = experience
  .filter((e) => !e.end)
  .map((e) => e.shortLabel ?? e.company.split(' ').pop() ?? e.company);

const stackShort = skills.main.slice(0, 3).map((s) => s.title);

const githubLink = nav.find((n) => n.slug === 'github');
const telegramLink = nav.find((n) => n.slug === 'telegram');
const xLink = nav.find((n) => n.slug === 'x');
const linkedinLink = nav.find((n) => n.slug === 'linkedin');
const contactLinks = [
  ...(githubLink ? [{ href: githubLink.href, label: 'github' }] : []),
  ...(telegramLink ? [{ href: telegramLink.href, label: 'tg' }] : []),
  { href: `mailto:${email}`, label: 'mail' }
];

function handleFromUrl(href: string): string {
  try {
    const url = new URL(href);
    const path = url.pathname.replace(/^\/+|\/+$/g, '');
    return path || url.hostname;
  } catch {
    return href;
  }
}

const connectLinks = [
  { href: `mailto:${email}`, label: 'email', handle: email, slug: 'email' },
  ...(xLink
    ? [
        {
          href: xLink.href,
          label: 'x.com',
          handle: `@${handleFromUrl(xLink.href)}`,
          slug: 'x'
        }
      ]
    : []),
  ...(linkedinLink
    ? [
        {
          href: linkedinLink.href,
          label: 'linkedin',
          handle: handleFromUrl(linkedinLink.href),
          slug: 'linkedin'
        }
      ]
    : []),
  ...(telegramLink
    ? [
        {
          href: telegramLink.href,
          label: 'telegram',
          handle: `@${handleFromUrl(telegramLink.href)}`,
          slug: 'telegram'
        }
      ]
    : [])
];

const longPathYearRe = /^(\d{4})\s*год:\s*(.+)$/i;
const longPath: { year: number; title: string; description: string }[] = [];
for (const block of about) {
  for (const line of block.split('\n')) {
    const m = line.match(longPathYearRe);
    if (!m) continue;
    const year = Number(m[1]);
    const body = m[2].trim();
    const splitIdx = body.search(/[.!?](?:\s|$)/);
    const title = splitIdx > 0 ? body.slice(0, splitIdx) : body;
    const description = splitIdx > 0 ? body.slice(splitIdx + 2).trim() : '';
    longPath.push({ year, title: title.trim(), description });
  }
}
longPath.sort((a, b) => a.year - b.year);

const aboutShort = about[0]?.split('\n').slice(0, 2) ?? [];

const RU_MONTHS: Record<string, number> = {
  январь: 0,
  февраль: 1,
  март: 2,
  апрель: 3,
  май: 4,
  июнь: 5,
  июль: 6,
  август: 7,
  сентябрь: 8,
  октябрь: 9,
  ноябрь: 10,
  декабрь: 11
};

function parseRuMonthYear(value: string): Date | null {
  const parts = value.trim().toLowerCase().split(/\s+/);
  if (parts.length !== 2) return null;
  const month = RU_MONTHS[parts[0]];
  const year = Number.parseInt(parts[1], 10);
  if (month === undefined || Number.isNaN(year)) return null;
  return new Date(year, month, 1);
}

function plural(n: number, one: string, few: string, many: string): string {
  const mod100 = n % 100;
  const mod10 = n % 10;
  if (mod100 >= 11 && mod100 <= 14) return many;
  if (mod10 === 1) return one;
  if (mod10 >= 2 && mod10 <= 4) return few;
  return many;
}

function formatDuration(begin: string, end?: string): string {
  const start = parseRuMonthYear(begin);
  const stop = end ? parseRuMonthYear(end) : new Date();
  if (!start || !stop) return '';
  const months =
    (stop.getFullYear() - start.getFullYear()) * 12 +
    (stop.getMonth() - start.getMonth()) +
    1;
  if (months <= 0) return '';
  const years = Math.floor(months / 12);
  const rest = months % 12;
  const parts: string[] = [];
  if (years) parts.push(`${years} ${plural(years, 'год', 'года', 'лет')}`);
  if (rest) parts.push(`${rest} ${plural(rest, 'месяц', 'месяца', 'месяцев')}`);
  return parts.join(' · ');
}

type DescriptionBlock = {
  label?: string;
  isBulleted: boolean;
  items: string[];
};

function parseDescription(desc?: string): DescriptionBlock[] {
  if (!desc) return [];
  const lines = desc.split('\n').filter((row) => row.trim().length > 0);
  const blocks: DescriptionBlock[] = [];
  let current: DescriptionBlock = { isBulleted: false, items: [] };
  for (const raw of lines) {
    const line = raw.trim();
    if (/:$/.test(line) && !line.startsWith('-')) {
      if (current.items.length || current.label) blocks.push(current);
      const label = line.slice(0, -1);
      current = {
        label,
        isBulleted: /достижения|обязанности/i.test(label),
        items: []
      };
    } else if (line.startsWith('- ')) {
      current.items.push(line.slice(2));
    } else {
      current.items.push(line);
    }
  }
  if (current.items.length || current.label) blocks.push(current);
  return blocks;
}
---

<Layout title={fullName}>
  <main class="mx-auto w-full max-w-[1280px] 2xl:max-w-[1440px]">
    <Header
      client:load
      {shortName}
      {position}
      {email}
      {location}
      {currentJobs}
      {currentRole}
      {stackShort}
      {contactLinks}
      {connectLinks}
      {sections}
    />

    {
      aboutShort.length > 0 && (
        <Section client:load number="01" title="Обо мне" id="about">
          <article class="space-y-6 text-base leading-relaxed sm:text-lg 2xl:text-xl">
            {aboutShort.map((row) => (
              <p class="text-ink-soft dark:text-ink-dark-soft">{row}</p>
            ))}
          </article>
        </Section>
      )
    }

    {
      longPath.length > 0 && (
        <Section client:load number="02" title="Долгий путь" id="longpath">
          <section>
            {longPath.map((row, i) => (
              <LongPathRow
                client:load
                year={row.year}
                title={row.title}
                description={row.description}
                isLast={i === longPath.length - 1}
              />
            ))}
          </section>
        </Section>
      )
    }

    {
      experience?.length > 0 && (
        <Section
          client:load
          number="03"
          title="Опыт работы"
          meta={`${experience.length} ${plural(experience.length, 'место', 'места', 'мест')}`}
          id="experience"
        >
          {experience.map(
            (
              {
                company,
                position: pos,
                begin,
                end,
                description,
                skills: expSkills
              },
              i
            ) => {
              if (!company) return null;
              const blocks = parseDescription(description);
              const durationLabel = formatDuration(begin, end);
              return (
                <Article
                  client:load
                  title={company}
                  subtitle={pos}
                  dateLabel={`${begin}${end ? ` — ${end}` : ' — настоящее время'}`}
                  durationLabel={durationLabel}
                  index={i + 1}
                >
                  {blocks.length > 0 && (
                    <section class="space-y-4 text-sm leading-relaxed text-ink-soft sm:text-base 2xl:text-lg dark:text-ink-dark-soft">
                      {blocks.map((block) => (
                        <section class="space-y-2">
                          {block.label && (
                            <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                              {block.label}
                            </p>
                          )}
                          {block.isBulleted ? (
                            <ul class="space-y-1.5">
                              {block.items.map((item) => (
                                <li class="flex gap-2.5">
                                  <span
                                    class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-rust/70 dark:bg-rust-soft/70"
                                    aria-hidden="true"
                                  />
                                  <span>{item}</span>
                                </li>
                              ))}
                            </ul>
                          ) : (
                            block.items.map((row) => <p>{row}</p>)
                          )}
                        </section>
                      ))}
                    </section>
                  )}
                  {expSkills && expSkills.length > 0 && (
                    <ul class="flex flex-wrap gap-2 pt-3">
                      {expSkills.map(({ title, slug }) => (
                        <li
                          class="inline-flex items-center gap-1.5 rounded-sm border border-ink/15 px-2.5 py-1 transition hover:border-rust/40 dark:border-ink-dark/20 dark:hover:border-rust-soft/45"
                          title={title}
                        >
                          <i class="flex h-3.5 w-3.5 items-center justify-center text-muted dark:text-ink-dark-soft">
                            <TechIcon
                              client:load
                              slug={slug}
                              title={title}
                              size={14}
                            />
                          </i>
                          <span class="font-jetbrains-mono text-2xs tracking-label text-ink-soft uppercase 2xl:text-sm dark:text-ink-dark-soft">
                            {title}
                          </span>
                        </li>
                      ))}
                    </ul>
                  )}
                </Article>
              );
            }
          )}
        </Section>
      )
    }

    {
      projects?.length > 0 && (
        <Section
          client:load
          number="04"
          title="Проекты"
          meta={`${projects.length} ${plural(projects.length, 'проект', 'проекта', 'проектов')}`}
          id="projects"
        >
          <section class="grid gap-4 sm:gap-5 md:grid-cols-2 lg:grid-cols-3 2xl:gap-6">
            {projects.map((p, i) => (
              <ProjectCard
                client:load
                name={p.name}
                description={p.description}
                stack={p.stack}
                github={p.github}
                gitlab={p.gitlab}
                index={i + 1}
              />
            ))}
          </section>
        </Section>
      )
    }

    {
      timeline?.length > 0 && (
        <Section client:load number="05" title="Хронология" id="timeline">
          <section>
            {timeline.map(({ year, title, subtitle }) => (
              <TimelineRow
                client:load
                year={year}
                title={title}
                subtitle={subtitle}
              />
            ))}
          </section>
        </Section>
      )
    }

    {
      (skills.main?.length ||
        skills.hard?.languages?.length ||
        skills.hard?.technologies?.length ||
        skills.hard?.patterns?.length) && (
        <Section client:load number="06" title="Стек" id="stack">
          {skills.main?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                Основной стек
              </p>
              <ul class="flex flex-wrap gap-6 2xl:gap-8">
                {skills.main.map(({ title, slug }) => (
                  <li
                    class="flex items-center gap-3 text-ink dark:text-ink-dark"
                    title={title}
                  >
                    <i class="flex h-6 w-6 items-center justify-center">
                      <TechIcon
                        client:load
                        slug={slug}
                        title={title}
                        size={24}
                      />
                    </i>
                    <span class="text-sm sm:text-base">{title}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {techStack.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                Языки и технологии
              </p>
              <section class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
                {techStack.map(({ title, slug, description }) => (
                  <TechCard
                    client:load
                    title={title}
                    slug={slug}
                    description={description}
                  />
                ))}
              </section>
            </section>
          )}

          {skills.hard?.patterns?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                Паттерны
              </p>
              <ul class="flex flex-wrap gap-2">
                {skills.hard.patterns.map((name) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}

          {skills.tools?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                Инструменты
              </p>
              <ul class="flex flex-wrap gap-2">
                {skills.tools.map(({ name }) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}

          {skills.soft?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                Гибкие навыки
              </p>
              <ul class="flex flex-wrap gap-2">
                {skills.soft.map((name) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}

          {skills.other?.length > 0 && (
            <section class="space-y-4">
              <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                Другое
              </p>
              <ul class="flex flex-wrap gap-2">
                {skills.other.map(({ name }) => (
                  <li>
                    <Badge client:load name={name} />
                  </li>
                ))}
              </ul>
            </section>
          )}
        </Section>
      )
    }

    {
      (languages?.length || books?.length) && (
        <Section client:load number="07" title="Чтение и языки" id="reading">
          <section class="grid gap-10 md:grid-cols-2 2xl:gap-16">
            {languages?.length > 0 && (
              <section class="space-y-4">
                <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                  Языки
                </p>
                <ul class="space-y-3">
                  {languages.map(({ title, level }) => (
                    <li class="flex items-baseline justify-between gap-4 border-b border-ink/10 pb-3 dark:border-ink-dark/15">
                      <span class="text-base text-ink dark:text-ink-dark">
                        {title}
                      </span>
                      <span class="font-jetbrains-mono text-2xs tracking-label text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                        {level}
                      </span>
                    </li>
                  ))}
                </ul>
              </section>
            )}
            {books?.length > 0 && (
              <section class="space-y-4">
                <p class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft">
                  Прочитано
                </p>
                <ul class="space-y-3">
                  {books.map(({ name, author }) => (
                    <li class="space-y-1 border-b border-ink/10 pb-3 dark:border-ink-dark/15">
                      <p class="text-base text-ink dark:text-ink-dark">
                        {name}
                      </p>
                      <address class="font-jetbrains-mono text-2xs tracking-label text-muted uppercase not-italic 2xl:text-sm dark:text-ink-dark-soft">
                        {author}
                      </address>
                    </li>
                  ))}
                </ul>
              </section>
            )}
          </section>
        </Section>
      )
    }

    <footer
      id="contact"
      class="scroll-mt-24 border-t border-ink/12 px-4 pt-12 pb-16 sm:px-8 2xl:px-12 2xl:pt-16 2xl:pb-24 dark:border-ink-dark/15"
    >
      <section
        class="flex flex-wrap items-center justify-between gap-6 2xl:gap-10"
      >
        <section class="space-y-2">
          <p
            class="font-jetbrains-mono text-2xs tracking-meta text-muted uppercase 2xl:text-sm dark:text-ink-dark-soft"
          >
            Связаться
          </p>
          <a
            href={`mailto:${email}`}
            class="font-lora text-2xl text-rust italic underline decoration-rust/30 underline-offset-4 transition hover:decoration-rust sm:text-3xl 2xl:text-4xl dark:text-rust-soft"
          >
            {email}
          </a>
        </section>
        <nav class="flex flex-wrap items-center gap-5 2xl:gap-7">
          {
            nav.map(({ href, slug, title }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={title}
                class="flex items-center gap-2 text-ink-soft transition hover:text-rust dark:text-ink-dark-soft dark:hover:text-rust-soft"
              >
                <i class="flex h-5 w-5 items-center justify-center">
                  <TechIcon
                    client:load
                    slug={slug}
                    title={title}
                    size={18}
                  />
                </i>
                <span class="font-jetbrains-mono text-2xs tracking-label uppercase 2xl:text-sm">
                  {title}
                </span>
              </a>
            ))
          }
          {
            links.map(({ href, slug, title }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={title}
                class="flex items-center gap-2 text-ink-soft transition hover:text-rust dark:text-ink-dark-soft dark:hover:text-rust-soft"
              >
                <i class="flex h-5 w-5 items-center justify-center">
                  <TechIcon
                    client:load
                    slug={slug}
                    title={title}
                    size={18}
                  />
                </i>
                <span class="font-jetbrains-mono text-2xs tracking-label uppercase 2xl:text-sm">
                  {title}
                </span>
              </a>
            ))
          }
        </nav>
      </section>
    </footer>
  </main>
</Layout>
